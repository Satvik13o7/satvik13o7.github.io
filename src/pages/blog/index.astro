---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);
---

<BaseLayout
  title="Writing &mdash; Satvik"
  description="Posts on agent infrastructure, tool caches, and production AI."
>
  <section class="prose intro">
    <h1>Writing</h1>
    <p class="tagline">
      Notes on agent infrastructure, tool caches, and production AI.
    </p>
  </section>

  <section class="section">
    {
      posts.length === 0 ? (
        <p class="muted small">No posts yet.</p>
      ) : (
        <ul class="post-list">
          {posts.map((post) => (
            <li>
              <time datetime={post.data.date.toISOString().slice(0, 10)}>
                {post.data.date.toLocaleDateString('en-US', {
                  year: 'numeric',
                  month: 'short',
                  day: 'numeric',
                })}
              </time>
              <span>
                <a href={`/blog/${post.id}/`}>{post.data.title}</a>
                <span class="desc">{post.data.description}</span>
              </span>
            </li>
          ))}
        </ul>
      )
    }
  </section>
</BaseLayout>
