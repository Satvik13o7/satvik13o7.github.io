---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description: string;
  date: Date;
}

const { title, description, date } = Astro.props;
const formatted = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
const iso = date.toISOString().slice(0, 10);
---

<BaseLayout title={title} description={description} ogType="article">
  <article class="prose">
    <h1 class="post-title">{title}</h1>
    <p class="post-meta">
      <time datetime={iso}>{formatted}</time>
    </p>
    <p class="post-lead">{description}</p>
    <slot />
    <hr />
    <p class="small muted">
      Reach out: <a href="mailto:satvikumar02@gmail.com">satvikumar02@gmail.com</a>.
    </p>
  </article>
</BaseLayout>
